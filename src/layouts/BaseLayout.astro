---
import "../styles/tokens.css";
import "../styles/base.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { getEntry } from "astro:content";

interface Props {
  title: string;
  description?: string;
}

const siteEntry = await getEntry("site", "site");
if (!siteEntry) throw new Error("site.yml not loaded as 'site' collection entry");
const siteName = siteEntry.data.site.name;
const defaultDescription = siteEntry.data.site.description;

const { title, description } = Astro.props;
const fullTitle = title === siteName ? siteName : `${title} — ${siteName}`;
const metaDescription = description ?? defaultDescription;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to main content</a>
    <SiteHeader />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
