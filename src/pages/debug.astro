---
// Dev-only debug page. Lists every loaded entry across all collections.
// Will be hidden from production builds in step 10 polish.

import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, getEntry } from "astro:content";

const people = await getCollection("people");
const alumni = await getCollection("alumni");
const news = await getCollection("news");
const publications = await getCollection("publications");
const siteEntry = await getEntry("site", "site");

const peopleByRole = {
  phd_students: people.filter((p) => p.data.role_group === "phd_students"),
  masters_students: people.filter((p) => p.data.role_group === "masters_students"),
  postdocs: people.filter((p) => p.data.role_group === "postdocs"),
};

const newsSorted = [...news].sort((a, b) =>
  b.data.date.localeCompare(a.data.date),
);

const publicationsSorted = [...publications].sort(
  (a, b) => b.data.sort_key - a.data.sort_key,
);

const pubVenueCounts: Record<string, number> = {};
for (const p of publications) {
  const v = p.data.venue || "(none)";
  pubVenueCounts[v] = (pubVenueCounts[v] ?? 0) + 1;
}
const pubYearCounts: Record<string, number> = {};
for (const p of publications) {
  const y = String(p.data.year);
  pubYearCounts[y] = (pubYearCounts[y] ?? 0) + 1;
}
const pubKeywordCounts: Record<string, number> = {};
for (const p of publications) {
  for (const k of p.data.keywords) {
    pubKeywordCounts[k] = (pubKeywordCounts[k] ?? 0) + 1;
  }
}
const pubHighlightCount = publications.filter((p) => p.data.highlight).length;
const pubWithVideoCount = publications.filter((p) => p.data.video).length;
const pubWithPdfCount = publications.filter((p) => p.data.pdf).length;
const pubWithDoiCount = publications.filter((p) => p.data.doi).length;
const pubWithNoteCount = publications.filter((p) => p.data.note).length;
const pubWithLiteralAuthor = publications.filter((p) =>
  p.data.authors.some((a) => a.literal),
).length;
---

<BaseLayout title="Debug — content collections" description="Dev-only view of all loaded content.">
  <section class="container debug">
    <p class="debug__eyebrow mono">Dev only · Steps 3 + 4 verification</p>
    <h1 class="debug__h1">Content collections</h1>
    <p class="debug__lead">
      Every entry loaded from <code>content/</code> through Astro content
      collections, including BibTeX-derived publications. Counts and a JSON
      dump for each entry follow. If any field fails Zod validation, this page
      will not render — check the dev server log.
    </p>

    <nav class="debug__toc mono" aria-label="Sections">
      <a href="#site">site</a>
      <a href="#people">people ({people.length})</a>
      <a href="#alumni">alumni ({alumni.length})</a>
      <a href="#news">news ({news.length})</a>
      <a href="#publications">publications ({publications.length})</a>
    </nav>

    <section id="site">
      <h2 class="debug__h2">
        <span class="mono">site</span>
        <span class="debug__count mono">1 entry</span>
      </h2>
      {siteEntry && (
        <details open>
          <summary class="mono">site.yml → id: {siteEntry.id}</summary>
          <pre class="debug__pre">{JSON.stringify(siteEntry.data, null, 2)}</pre>
        </details>
      )}
    </section>

    <section id="people">
      <h2 class="debug__h2">
        <span class="mono">people</span>
        <span class="debug__count mono">{people.length} entries</span>
      </h2>
      {(["phd_students", "masters_students", "postdocs"] as const).map((group) => (
        <div class="debug__group">
          <h3 class="debug__h3 mono">
            {group} ({peopleByRole[group].length})
          </h3>
          {peopleByRole[group].length === 0 && (
            <p class="debug__empty">(empty)</p>
          )}
          {peopleByRole[group].map((p) => (
            <details>
              <summary class="mono">
                {p.data.slug} — {p.data.name} · {p.data.role}
              </summary>
              <pre class="debug__pre">{JSON.stringify(p.data, null, 2)}</pre>
            </details>
          ))}
        </div>
      ))}
    </section>

    <section id="alumni">
      <h2 class="debug__h2">
        <span class="mono">alumni</span>
        <span class="debug__count mono">{alumni.length} entries</span>
      </h2>
      {alumni.map((a) => (
        <details>
          <summary class="mono">
            {a.data.slug} — {a.data.name} · {a.data.placement_type}
          </summary>
          <pre class="debug__pre">{JSON.stringify(a.data, null, 2)}</pre>
        </details>
      ))}
    </section>

    <section id="news">
      <h2 class="debug__h2">
        <span class="mono">news</span>
        <span class="debug__count mono">{news.length} entries (sorted desc)</span>
      </h2>
      {newsSorted.map((n) => (
        <details>
          <summary class="mono">
            {n.data.date} — {n.data.title}
          </summary>
          <pre class="debug__pre">{JSON.stringify(n.data, null, 2)}</pre>
        </details>
      ))}
    </section>

    <section id="publications">
      <h2 class="debug__h2">
        <span class="mono">publications</span>
        <span class="debug__count mono">{publications.length} entries (sorted desc by year, month)</span>
      </h2>

      <div class="debug__stats mono">
        <div><strong>By venue:</strong> {Object.entries(pubVenueCounts).sort((a, b) => b[1] - a[1]).map(([k, v]) => `${k}=${v}`).join(", ")}</div>
        <div><strong>By year:</strong> {Object.entries(pubYearCounts).sort((a, b) => b[0].localeCompare(a[0])).map(([k, v]) => `${k}=${v}`).join(", ")}</div>
        <div><strong>By keyword:</strong> {Object.entries(pubKeywordCounts).sort((a, b) => b[1] - a[1]).map(([k, v]) => `${k}=${v}`).join(", ")}</div>
        <div><strong>highlight=true:</strong> {pubHighlightCount}</div>
        <div><strong>has pdf:</strong> {pubWithPdfCount} · <strong>video:</strong> {pubWithVideoCount} · <strong>doi:</strong> {pubWithDoiCount} · <strong>note:</strong> {pubWithNoteCount}</div>
        <div><strong>entries containing a literal/group author:</strong> {pubWithLiteralAuthor}</div>
      </div>

      {publicationsSorted.map((p) => (
        <details>
          <summary class="mono">
            [{p.data.year}{p.data.month ? `-${String(p.data.month).padStart(2, "0")}` : ""}] {p.data.venue} · {p.data.key} {p.data.highlight ? "★" : ""}
          </summary>
          <div class="debug__pub-preview">
            <p class="debug__pub-title">{p.data.title}</p>
            <p class="debug__pub-meta mono">{p.data.authors_display}</p>
            <p class="debug__pub-meta mono">{p.data.container}{p.data.pages ? `, pp. ${p.data.pages}` : ""}</p>
          </div>
          <pre class="debug__pre">{JSON.stringify(p.data, null, 2)}</pre>
        </details>
      ))}
    </section>
  </section>
</BaseLayout>

<style>
  .debug {
    padding-block: var(--space-8) var(--space-10);
    max-width: 80ch;
  }

  .debug__eyebrow {
    font-size: var(--text-xs);
    color: var(--color-accent);
    margin-bottom: var(--space-3);
  }

  .debug__h1 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
  }

  .debug__lead {
    color: var(--color-fg-muted);
    margin-bottom: var(--space-6);
  }

  .debug__toc {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    padding-block: var(--space-3);
    border-block: 0.5px solid var(--color-border);
    margin-bottom: var(--space-8);
    font-size: var(--text-sm);
  }

  .debug__toc a {
    color: var(--color-fg);
    text-decoration: none;
  }

  .debug__toc a:hover {
    color: var(--color-accent);
  }

  .debug__h2 {
    font-size: var(--text-lg);
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
  }

  .debug__count {
    font-size: var(--text-xs);
    color: var(--color-fg-faint);
    font-weight: var(--weight-regular);
  }

  .debug__h3 {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    font-weight: var(--weight-medium);
    margin-top: var(--space-5);
    margin-bottom: var(--space-2);
  }

  .debug__group {
    margin-bottom: var(--space-4);
  }

  .debug__empty {
    font-size: var(--text-sm);
    color: var(--color-fg-faint);
    font-style: italic;
  }

  details {
    border-top: 0.5px solid var(--color-border);
    padding-block: var(--space-2);
  }

  details:last-child {
    border-bottom: 0.5px solid var(--color-border);
  }

  summary {
    cursor: pointer;
    font-size: var(--text-sm);
    color: var(--color-fg);
    padding-block: var(--space-1);
  }

  summary:hover {
    color: var(--color-accent);
  }

  .debug__pre {
    background: var(--color-gray-tint);
    padding: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    line-height: 1.5;
    overflow-x: auto;
    margin-top: var(--space-2);
    margin-bottom: 0;
    color: var(--color-fg);
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--color-gray-tint);
    padding: 1px 4px;
  }

  .debug__stats {
    font-size: var(--text-xs);
    color: var(--color-fg-muted);
    padding: var(--space-3);
    background: var(--color-gray-tint);
    margin-bottom: var(--space-4);
    line-height: 1.7;
  }

  .debug__stats strong {
    font-weight: var(--weight-medium);
    color: var(--color-fg);
  }

  .debug__pub-preview {
    padding: var(--space-2) 0 var(--space-1);
  }

  .debug__pub-title {
    font-size: var(--text-sm);
    color: var(--color-fg);
    margin-bottom: var(--space-1);
  }

  .debug__pub-meta {
    font-size: var(--text-xs);
    color: var(--color-fg-muted);
  }
</style>
