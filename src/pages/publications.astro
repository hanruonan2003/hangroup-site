---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, getEntry } from "astro:content";
import { url } from "../lib/url.ts";

const publications = await getCollection("publications");
const siteEntry = await getEntry("site", "site");
if (!siteEntry) throw new Error("site.yml not loaded");

const scholarUrl = siteEntry.data.pi.scholar;

// Sort newest-first.
const sorted = [...publications].sort(
  (a, b) => b.data.sort_key - a.data.sort_key,
);

// Group by year.
const byYear = new Map<number, typeof sorted>();
for (const p of sorted) {
  const y = p.data.year;
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(p);
}
const years = [...byYear.keys()].sort((a, b) => b - a);

// Filter chip options — sorted for stable order.
const allYears = years.map(String);
const allVenues = [
  ...new Set(sorted.map((p) => p.data.venue).filter(Boolean)),
].sort();
const allTopics = [
  ...new Set(sorted.flatMap((p) => p.data.keywords)),
].sort();

const totalCount = sorted.length;

// Helper for the search index attribute — title + author display names, lowercased.
const searchText = (pub: (typeof sorted)[number]): string =>
  `${pub.data.title} ${pub.data.authors_display}`.toLowerCase();

// Format a topic keyword for display: "imaging-radar" → "imaging radar".
const formatTopic = (k: string): string => k.replace(/-/g, " ");
---

<BaseLayout
  title="Publications"
  description={`Selected publications from ${siteEntry.data.site.name}. ${totalCount} entries.`}
>
  <section class="container pubs">
    <header class="pubs__header">
      <div class="pubs__title-row">
        <h1 class="pubs__h1">Publications</h1>
        <div class="pubs__actions mono">
          <a class="pubs__action" href={url("/publications.bib")} download>
            .bib <span aria-hidden="true">↓</span>
          </a>
          {scholarUrl && (
            <a
              class="pubs__action"
              href={scholarUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              Google Scholar
            </a>
          )}
        </div>
      </div>

      <details class="pubs__filters" data-filters>
        <summary class="pubs__filters-toggle mono">
          <span>Filters</span>
          <span aria-hidden="true" class="pubs__filters-caret">▾</span>
        </summary>

        <div class="pubs__toolbar" role="group" aria-label="Filter publications">
        <input
          class="pubs__search"
          type="search"
          data-search
          placeholder="Search title or author…"
          aria-label="Search publications"
          autocomplete="off"
          spellcheck="false"
        />

        <div class="pubs__chip-group" role="group" aria-label="Year">
          {allYears.map((y) => (
            <button
              type="button"
              class="chip mono"
              data-chip={`year:${y}`}
              aria-pressed="false"
            >
              {y}
            </button>
          ))}
        </div>

        <div class="pubs__chip-group" role="group" aria-label="Venue">
          {allVenues.map((v) => (
            <button
              type="button"
              class="chip mono"
              data-chip={`venue:${v}`}
              aria-pressed="false"
            >
              {v}
            </button>
          ))}
        </div>

        <div class="pubs__chip-group" role="group" aria-label="Topic">
          {allTopics.map((t) => (
            <button
              type="button"
              class="chip mono"
              data-chip={`topic:${t}`}
              aria-pressed="false"
            >
              {formatTopic(t)}
            </button>
          ))}
        </div>
      </div>

        <p class="pubs__status mono">
          <span data-total-count>{totalCount}</span> papers
          <span aria-hidden="true" class="pubs__status-sep">·</span>
          <button type="button" class="pubs__clear" data-clear>Clear filters</button>
        </p>
      </details>
    </header>

    <div class="pubs__empty mono" data-empty-state hidden>
      No publications match the current filters.
    </div>

    <div class="pubs__list">
      {years.map((year) => {
        const entries = byYear.get(year)!;
        return (
          <section class="year-section" data-year-section={String(year)}>
            <h2 class="year-section__h2">
              <span class="year-section__num mono">{year}</span>
              <span class="year-section__count mono">
                <span data-year-count>{entries.length}</span> paper{entries.length === 1 ? "" : "s"}
              </span>
            </h2>
            <ul class="year-section__list">
              {entries.map((pub) => {
                const d = pub.data;
                const venueLabel = d.venue || d.container || "";
                const monthLabel = d.month
                  ? new Date(d.year, d.month - 1, 1).toLocaleString("en-US", {
                      month: "short",
                    })
                  : "";
                const dateLabel = monthLabel ? `${monthLabel} ${d.year}` : String(d.year);
                const showContainer = d.container && d.container !== d.venue;
                const visibleAuthors = d.authors.filter(
                  (a) => !(a.literal && a.family === "others"),
                );
                const authorsLine = visibleAuthors.map((a) => a.raw).join(", ");
                return (
                  <li
                    class="entry"
                    id={d.key}
                    data-pub-entry
                    data-pub-key={d.key}
                    data-pub-year={String(d.year)}
                    data-pub-venue={d.venue}
                    data-pub-topics={d.keywords.join(" ")}
                    data-pub-text={searchText(pub)}
                  >
                    <p class="entry__meta mono">
                      {venueLabel && (
                        <span class="entry__meta-item entry__meta-item--venue">{venueLabel}</span>
                      )}
                      <span class="entry__meta-item">{dateLabel}</span>
                      {d.keywords.map((k) => (
                        <span class="entry__meta-item entry__meta-item--topic">{formatTopic(k)}</span>
                      ))}
                      {d.highlight && (
                        <span class="entry__meta-item entry__meta-item--highlight">Highlight</span>
                      )}
                    </p>
                    <h3 class="entry__title">{d.title}</h3>
                    <div class="entry__byline">
                      <span class="entry__authors">{authorsLine}</span>
                      {showContainer && (
                        <>
                          <span class="entry__byline-sep" aria-hidden="true">—</span>
                          <span class="entry__container">
                            {d.container}{d.pages ? `, pp. ${d.pages}` : ""}
                          </span>
                        </>
                      )}
                      {d.note && (
                        <span class="entry__note">
                          <span aria-hidden="true">— </span><em>{d.note}</em>
                        </span>
                      )}
                      <span class="entry__inline-links mono">
                        {d.pdf && (
                          <a href={d.pdf} class="entry__link">PDF</a>
                        )}
                        {d.video && (
                          <a href={d.video} class="entry__link" target="_blank" rel="noopener noreferrer">Video</a>
                        )}
                      </span>
                    </div>
                  </li>
                );
              })}
            </ul>
          </section>
        );
      })}
    </div>
  </section>
</BaseLayout>

<script>
  const $ = <T extends Element = Element>(sel: string, root: ParentNode = document): T | null =>
    root.querySelector<T>(sel);
  const $$ = <T extends Element = Element>(sel: string, root: ParentNode = document): T[] =>
    Array.from(root.querySelectorAll<T>(sel));

  type EntryRef = {
    el: HTMLElement;
    year: string;
    venue: string;
    topics: string[];
    text: string;
  };
  type YearSection = { el: HTMLElement; year: string };

  const state = {
    search: "",
    years: new Set<string>(),
    venues: new Set<string>(),
    topics: new Set<string>(),
  };

  const entries: EntryRef[] = $$("[data-pub-entry]").map((el) => {
    const html = el as HTMLElement;
    return {
      el: html,
      year: html.dataset.pubYear ?? "",
      venue: html.dataset.pubVenue ?? "",
      topics: (html.dataset.pubTopics ?? "").split(" ").filter(Boolean),
      text: html.dataset.pubText ?? "",
    };
  });

  const yearSections: YearSection[] = $$("[data-year-section]").map((el) => ({
    el: el as HTMLElement,
    year: (el as HTMLElement).dataset.yearSection ?? "",
  }));

  const totalEl = $<HTMLElement>("[data-total-count]");
  const emptyEl = $<HTMLElement>("[data-empty-state]");
  const searchEl = $<HTMLInputElement>("[data-search]");
  const clearEl = $<HTMLButtonElement>("[data-clear]");

  function matches(e: EntryRef): boolean {
    if (state.search && !e.text.includes(state.search)) return false;
    if (state.years.size && !state.years.has(e.year)) return false;
    if (state.venues.size && !state.venues.has(e.venue)) return false;
    if (state.topics.size && !e.topics.some((t) => state.topics.has(t))) return false;
    return true;
  }

  function applyFilters(): void {
    let total = 0;
    for (const e of entries) {
      const visible = matches(e);
      e.el.hidden = !visible;
      if (visible) total++;
    }
    for (const sec of yearSections) {
      let visibleInYear = 0;
      for (const e of entries) {
        if (e.year === sec.year && !e.el.hidden) visibleInYear++;
      }
      sec.el.hidden = visibleInYear === 0;
      const yc = sec.el.querySelector<HTMLElement>("[data-year-count]");
      if (yc) yc.textContent = String(visibleInYear);
    }
    if (emptyEl) emptyEl.hidden = total > 0;
    if (totalEl) totalEl.textContent = String(total);
  }

  searchEl?.addEventListener("input", () => {
    state.search = (searchEl.value ?? "").toLowerCase();
    applyFilters();
  });

  $$<HTMLButtonElement>("[data-chip]").forEach((chip) => {
    chip.addEventListener("click", () => {
      const raw = chip.dataset.chip ?? "";
      const idx = raw.indexOf(":");
      if (idx === -1) return;
      const group = raw.slice(0, idx);
      const value = raw.slice(idx + 1);
      const set =
        group === "year" ? state.years :
        group === "venue" ? state.venues :
        group === "topic" ? state.topics :
        null;
      if (!set) return;
      if (set.has(value)) {
        set.delete(value);
        chip.classList.remove("is-active");
        chip.setAttribute("aria-pressed", "false");
      } else {
        set.add(value);
        chip.classList.add("is-active");
        chip.setAttribute("aria-pressed", "true");
      }
      applyFilters();
    });
  });

  clearEl?.addEventListener("click", () => {
    state.search = "";
    state.years.clear();
    state.venues.clear();
    state.topics.clear();
    if (searchEl) searchEl.value = "";
    $$<HTMLButtonElement>("[data-chip].is-active").forEach((c) => {
      c.classList.remove("is-active");
      c.setAttribute("aria-pressed", "false");
    });
    applyFilters();
  });

  // Deep-linking: ?topic=imaging-radar,communication&venue=ISSCC&year=2022
  // The research page links here with these params to land on a pre-filtered view.
  function applyParam(group: "year" | "venue" | "topic", set: Set<string>, raw: string): void {
    for (const v of raw.split(",").map((s) => s.trim()).filter(Boolean)) {
      set.add(v);
      const chip = document.querySelector<HTMLButtonElement>(
        `[data-chip="${group}:${v}"]`,
      );
      if (chip) {
        chip.classList.add("is-active");
        chip.setAttribute("aria-pressed", "true");
      }
    }
  }
  const params = new URLSearchParams(window.location.search);
  applyParam("topic", state.topics, params.get("topic") ?? "");
  applyParam("venue", state.venues, params.get("venue") ?? "");
  applyParam("year", state.years, params.get("year") ?? "");
  if (state.topics.size || state.venues.size || state.years.size) {
    applyFilters();
  }

  // Filters are collapsed by default so mobile readers see papers sooner.
  // On desktop (>= 720px) we force-open the panel and hide the toggle via CSS,
  // so desktop behaves exactly as before. The matchMedia listener keeps things
  // sane if the viewport is resized (or the user rotates a tablet).
  const filtersDetails = document.querySelector<HTMLDetailsElement>("[data-filters]");
  if (filtersDetails) {
    const desktop = window.matchMedia("(min-width: 720px)");
    const syncFiltersToViewport = (): void => {
      if (desktop.matches) filtersDetails.open = true;
    };
    syncFiltersToViewport();
    // If a deep-link param activated any chips, surface them on mobile too.
    if (state.topics.size || state.venues.size || state.years.size) {
      filtersDetails.open = true;
    }
    desktop.addEventListener("change", syncFiltersToViewport);
  }
</script>

<style>
  .pubs {
    padding-block: var(--space-6) var(--space-10);
  }

  /* Header */

  .pubs__header {
    margin-bottom: var(--space-6);
  }

  .pubs__title-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-3);
  }

  .pubs__h1 {
    font-size: var(--text-xl);
  }

  @media (min-width: 720px) {
    .pubs__h1 {
      font-size: var(--text-2xl);
    }
  }

  .pubs__actions {
    display: flex;
    gap: var(--space-3);
    font-size: var(--text-xs);
  }

  .pubs__action {
    color: var(--color-fg);
    text-decoration: none;
    border-bottom: 0.5px solid var(--color-border);
    padding-bottom: 1px;
  }

  .pubs__action:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  /* Filters wrapper — collapsed by default on mobile so the paper list
     appears sooner. JS opens it on desktop (>= 720px) and on deep-links;
     the toggle is hidden on desktop via the media query below. */

  .pubs__filters {
    /* No border around the details element itself. */
  }

  .pubs__filters-toggle {
    cursor: pointer;
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 6px 0;
    font-size: var(--text-xs);
    color: var(--color-fg-muted);
    border-bottom: 0.5px solid var(--color-border);
    width: 100%;
  }

  .pubs__filters-toggle::-webkit-details-marker {
    display: none;
  }

  .pubs__filters-caret {
    display: inline-block;
    transition: transform 0.15s ease;
    color: var(--color-fg-faint);
  }

  .pubs__filters[open] .pubs__filters-caret {
    transform: rotate(180deg);
  }

  @media (min-width: 720px) {
    .pubs__filters-toggle {
      display: none;
    }
  }

  /* Toolbar — search + chip groups on one row, wraps as needed */

  .pubs__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    padding-block: var(--space-2);
    border-block: 0.5px solid var(--color-border);
  }

  .pubs__search {
    width: 240px;
    flex-shrink: 0;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-fg);
    background: transparent;
    border: 0;
    border-bottom: 0.5px solid var(--color-border);
    padding: 4px 0;
    min-height: 32px;
  }

  @media (max-width: 480px) {
    .pubs__search {
      width: 100%;
    }
  }

  .pubs__search:focus {
    outline: 0;
    border-bottom-color: var(--color-accent);
  }

  .pubs__chip-group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    align-items: center;
  }

  /* Thin vertical divider between groups (desktop only — on wrap, dividers
     would look odd at the start of a new line, so we drop them under 480px). */
  .pubs__chip-group + .pubs__chip-group {
    padding-left: var(--space-3);
    margin-left: var(--space-1);
    border-left: 0.5px solid var(--color-border);
  }

  @media (max-width: 480px) {
    .pubs__chip-group + .pubs__chip-group {
      padding-left: 0;
      margin-left: 0;
      border-left: 0;
    }
  }

  .chip {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-fg);
    background: transparent;
    border: 0.5px solid var(--color-border);
    padding: 0 8px;
    cursor: pointer;
    line-height: 1.4;
    min-height: 24px;
  }

  /* Touch targets a bit larger on coarse pointers. */
  @media (pointer: coarse) {
    .chip {
      min-height: 32px;
      padding: 4px 10px;
    }
  }

  .chip:hover {
    border-color: var(--color-fg);
  }

  .chip.is-active {
    background: var(--color-accent);
    color: var(--color-bg);
    border-color: var(--color-accent);
  }

  /* Status line — paper count + clear, compact */

  .pubs__status {
    margin-top: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-fg-faint);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: baseline;
  }

  .pubs__status-sep {
    color: var(--color-fg-faint);
  }

  .pubs__clear {
    font-family: inherit;
    font-size: inherit;
    color: var(--color-fg-faint);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .pubs__clear:hover {
    color: var(--color-accent);
  }

  .pubs__empty {
    padding: var(--space-6);
    text-align: center;
    color: var(--color-fg-muted);
    font-size: var(--text-sm);
  }

  /* Year sections (kept as-is) */

  .year-section {
    margin-bottom: var(--space-8);
  }

  .year-section__h2 {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-1);
    border-bottom: 0.5px solid var(--color-border);
  }

  .year-section__num {
    font-size: var(--text-lg);
    color: var(--color-accent);
    font-weight: var(--weight-medium);
  }

  .year-section__count {
    font-size: var(--text-xs);
    color: var(--color-fg-faint);
    font-weight: var(--weight-regular);
  }

  .year-section__list {
    list-style: none;
  }

  /* Entry — three-line layout, tight */

  .entry {
    padding-block: var(--space-2);
    border-bottom: 0.5px solid var(--color-border);
    line-height: 1.35;
  }

  .entry:first-child {
    padding-top: var(--space-1);
  }

  .entry__meta {
    font-size: 11px;
    color: var(--color-fg-faint);
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    align-items: baseline;
    margin-bottom: 2px;
    line-height: 1.4;
  }

  .entry__meta-item {
    padding: 0 6px 0 0;
  }

  .entry__meta-item + .entry__meta-item::before {
    content: "· ";
    color: var(--color-fg-faint);
    margin-right: 6px;
  }

  .entry__meta-item--venue {
    color: var(--color-accent);
    font-weight: var(--weight-medium);
  }

  .entry__meta-item--topic {
    color: var(--color-fg-muted);
  }

  .entry__meta-item--highlight {
    color: var(--color-amber);
  }

  .entry__title {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    line-height: 1.35;
    margin-bottom: 2px;
  }

  @media (min-width: 720px) {
    .entry__title {
      font-size: var(--text-md);
    }
  }

  .entry__byline {
    font-size: 13px;
    color: var(--color-fg-muted);
    line-height: 1.4;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 4px;
  }

  .entry__authors {
    /* author list flows inline; long lists wrap naturally */
  }

  .entry__byline-sep {
    color: var(--color-fg-faint);
  }

  .entry__container {
    color: var(--color-fg-muted);
  }

  .entry__note {
    color: var(--color-fg-faint);
  }

  .entry__note em {
    font-style: italic;
  }

  .entry__inline-links {
    margin-left: auto;
    display: inline-flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    font-size: 11px;
    align-items: baseline;
  }

  .entry__link {
    color: var(--color-fg);
    text-decoration: none;
    border-bottom: 0.5px solid var(--color-border);
    padding-bottom: 1px;
    cursor: pointer;
    background: transparent;
    font-family: var(--font-mono);
  }

  .entry__link:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  [hidden] {
    display: none !important;
  }
</style>
