---
// Renders a square headshot for a person.
//
// If a file content/people/photos/<slug>.{jpg,jpeg,png} exists, it is bundled
// by Vite at build time and rendered as <img>. Otherwise we fall back to an
// initials placeholder. The lookup is by slug, not by the YAML `photo` field,
// so file extensions can drift from the YAML without breaking anything.

const photoModules = import.meta.glob<string>(
  "../../content/people/photos/*.{jpg,jpeg,png,JPG,JPEG,PNG}",
  { eager: true, query: "?url", import: "default" },
);

const photoBySlug: Record<string, string> = {};
for (const [path, url] of Object.entries(photoModules)) {
  const filename = path.split("/").pop()!;
  const slug = filename.replace(/\.(jpg|jpeg|png)$/i, "");
  photoBySlug[slug] = url;
}

interface Props {
  name: string;
  slug?: string;
  size?: "small" | "medium" | "large";
}
const { name, slug, size = "medium" } = Astro.props;
const photoUrl = slug ? photoBySlug[slug] : undefined;

function getInitials(n: string): string {
  const cleaned = n.replace(/\([^)]*\)/g, " ").trim();
  const parts = cleaned.split(/\s+/).filter(Boolean);
  if (parts.length === 0) return "?";
  if (parts.length === 1) return parts[0][0]!.toUpperCase();
  return (parts[0][0]! + parts[parts.length - 1]![0]!).toUpperCase();
}
const initials = getInitials(name);
---

{photoUrl ? (
  <img
    class={`person-photo person-photo--${size}`}
    src={photoUrl}
    alt={name}
    loading="lazy"
    decoding="async"
  />
) : (
  <div class={`person-photo person-photo--${size}`} aria-hidden="true">
    <span class="person-photo__initials mono">{initials}</span>
  </div>
)}

<style>
  .person-photo {
    aspect-ratio: 1;
    background: var(--color-gray-tint);
    border: 0.5px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    object-fit: cover;
  }

  .person-photo--small {
    width: 64px;
  }

  .person-photo--medium {
    width: 100%;
  }

  .person-photo--large {
    width: 180px;
  }

  .person-photo__initials {
    color: var(--color-fg-muted);
    font-size: var(--text-md);
    font-weight: var(--weight-medium);
  }

  .person-photo--large .person-photo__initials {
    font-size: var(--text-2xl);
  }
</style>
