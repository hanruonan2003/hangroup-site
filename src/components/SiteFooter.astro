---
// TODO step 3: pull address and group name from site.yml.
const year = new Date().getFullYear();
const groupName = "Terahertz Integrated Electronics Group";
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <p class="site-footer__address mono">
      <span>MIT Microsystems Technology Laboratories</span>
      <span aria-hidden="true"> · </span>
      <span>Building 39, Room 527A</span>
      <span aria-hidden="true"> · </span>
      <span>60 Vassar Street, Cambridge, MA 02139</span>
    </p>
    <p class="site-footer__meta">
      © {year} {groupName}, MIT
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 0.5px solid var(--color-border);
    margin-top: var(--space-12);
    padding-block: var(--space-6);
  }

  .site-footer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .site-footer__address {
    font-size: var(--text-xs);
    color: var(--color-fg-muted);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .site-footer__meta {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
  }
</style>
