---
import { getEntry } from "astro:content";
import { url } from "../lib/url.ts";

const siteEntry = await getEntry("site", "site");
if (!siteEntry) throw new Error("site.yml not loaded");
const siteName = siteEntry.data.site.name;

type NavItem = { href: string; label: string };
const navItems: NavItem[] = [
  { href: "/", label: "Home" },
  { href: "/research/", label: "Research" },
  { href: "/people/", label: "People" },
  { href: "/publications/", label: "Publications" },
  { href: "/news/", label: "News" },
  { href: "/contact/", label: "Contact" },
];

// Strip the configured base from the request path before comparing nav items,
// which are authored as "/people/" etc. (without base).
const BASE = import.meta.env.BASE_URL.replace(/\/+$/, "");
const currentPath = (Astro.url.pathname.replace(BASE, "") || "/");
const isActive = (href: string): boolean => {
  if (href === "/") return currentPath === "/" || currentPath === "";
  return currentPath === href || currentPath.startsWith(href);
};
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-mark" href={url("/")} aria-label={`${siteName} home`}>
      <span class="site-mark__square" aria-hidden="true"></span>
      <span class="site-mark__name">{siteName}</span>
      <span class="site-mark__affiliations" aria-label="Affiliations: MIT, RLE, MTL">
        <a
          class="affiliation-logo affiliation-logo--mit"
          href="https://www.mit.edu/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Massachusetts Institute of Technology"
        >
          <img src={url("/logos/mit.png")} alt="MIT" />
        </a>
        <a
          class="affiliation-logo"
          href="https://www.rle.mit.edu/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Research Laboratory of Electronics at MIT"
        >
          <img src={url("/logos/rle-mark.png")} alt="RLE" />
        </a>
        <a
          class="affiliation-logo affiliation-logo--mtl"
          href="https://www.mtl.mit.edu/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Microsystems Technology Laboratories at MIT"
        >
          <img src={url("/logos/mtl-mark.png")} alt="MTL" />
        </a>
      </span>
    </a>
    <nav class="site-nav" aria-label="Primary">
      <ul>
        {navItems.map((item) => (
          <li>
            <a
              href={url(item.href)}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 0.5px solid var(--color-border);
    padding-block: var(--space-4);
  }

  .site-header__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: flex-start;
  }

  @media (min-width: 880px) {
    .site-header__inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      gap: var(--space-6);
    }
  }

  .site-mark {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    color: var(--color-fg);
    flex-wrap: wrap;
  }

  .site-mark:hover {
    color: var(--color-fg);
  }

  .site-mark__square {
    display: inline-block;
    width: 12px;
    height: 12px;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  .site-mark__name {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
  }

  /* Affiliation logos — small inline marks linking to MIT / RLE / MTL.
     No background pill; RLE's red square and MTL's yellow wordmark read
     well on dark mode in their original brand colors. The MIT wordmark
     is a flat black mark, so it's filtered to white for dark mode. */
  .site-mark__affiliations {
    display: inline-flex;
    align-items: center;
    gap: 0;
    margin-left: 4px;
  }

  .affiliation-logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    line-height: 0;
    opacity: 0.9;
    transition: opacity 0.15s ease;
  }

  .affiliation-logo:hover {
    opacity: 1;
  }

  /* Thin vertical pipe separator BEFORE every logo — including the first,
     so the affiliations cluster reads as "<name> | MIT | rle | MTL". */
  .affiliation-logo::before {
    content: "|";
    color: var(--color-fg-faint);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1;
    margin-inline: 4px;
    align-self: center;
  }

  .affiliation-logo img {
    height: 18px;
    width: auto;
    display: block;
  }

  /* MIT wordmark is a flat black mark; flip it to white for dark mode. The
     wordmark's rightmost element (the T's horizontal bar) ends midway up the
     bounding box, so a small negative right margin lets the next pipe sit
     visually flush with the wordmark instead of marooned in empty space. */
  .affiliation-logo--mit img {
    height: 20px;
    filter: invert(1);
    margin-right: -10px;
  }

  /* MTL wordmark sits a hair lower visually because of the letter shapes;
     a small downscale keeps it balanced with the RLE square next to it. */
  .affiliation-logo--mtl img {
    height: 17px;
  }

  .site-nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4) var(--space-5);
    list-style: none;
  }

  .site-nav a {
    display: inline-block;
    font-size: var(--text-sm);
    text-decoration: none;
    color: var(--color-fg);
    padding-block: 2px;
    border-bottom: 2px solid transparent;
  }

  .site-nav a:hover {
    color: var(--color-accent);
  }

  .site-nav a[aria-current="page"] {
    border-bottom-color: var(--color-accent);
  }
</style>
